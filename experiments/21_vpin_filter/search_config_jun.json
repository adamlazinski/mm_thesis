{
    "data_dir":   "data/real",
    "start":      "2025-06-11",
    "end":        "2025-06-13",
    "output":     "search/21_vpin_search_jun.csv",

    "strategy":   "pure_as_vpin",
    "order_size": 0.001,
    "tick_size":  0.01,
    "maker_fee":  0.0,
    "timestamp":  "time_exchange",

    "fixed": {
        "latency":            0.1,
        "quote_freq":         0.5,
        "min_spread_bps":     0.05,
        "max_inventory":      0.02,
        "vol_window":         120,
        "arrival_window":     60,
        "ewma_alpha":         0.9,
        "guardrail":          false,
        "t_scaling":          9702.0,
        "vpin_n_buckets":     50
    },

    "search": {
        "gamma":              ["log_uniform", 0.05, 5.0],
        "vpin_threshold":     ["uniform", 0.2, 0.7],
        "vpin_bucket_volume": ["log_uniform", 0.1, 2.0]
    },

    "scoring": {
        "metric":        "mean_pnl",
        "min_fills":     20,
        "min_fill_rate": 0.001
    },

    "n_trials":  200,
    "n_workers": 7,
    "seed":      42,
    "top_n":     10,
    "notes":     "VPIN threshold + bucket volume search on June data"
}
