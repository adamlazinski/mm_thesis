{
    "data_dir":   "data/real",
    "start":      "2025-05-13",
    "end":        "2025-05-13",
    "output":     "search/14_vol_inventory_wide_search.csv",

    "strategy":   "vol_inventory",
    "order_size": 0.001,
    "tick_size":  0.01,
    "maker_fee":  0.0,
    "timestamp":  "time_exchange",

    "fixed": {
        "latency":            0.1,
        "quote_freq":         0.5,
        "max_inventory":      0.02,
        "min_spread_bps":     0.0,
        "vol_window":         120,
        "arrival_window":     60,
        "ewma_alpha":         0.9,
        "guardrail":          false,
        "short_gap":          2.0,
        "long_gap":           30.0,
        "kappa_force_interval": 60.0
    },

    "search": {
        "vi_alpha":        ["log_uniform", 0.15, 1.5],
        "vi_gamma_inv":    ["log_uniform", 0.2, 5.0],
        "tolerance_ticks": ["uniform", 1.0, 20.0]
    },

    "scoring": {
        "metric":        "mm_only_pnl",
        "min_fills":     10,
        "min_fill_rate": 0.00005
    },

    "n_trials":  60,
    "n_workers": 6,
    "seed":      44,
    "top_n":     10,
    "notes":     "Wide-spread patience search: sweep alpha (spread size), gamma_inv (inventory skew), and tolerance_ticks (order lifetime). alpha=0.3 -> ~64 tick half-spread at median vol. tolerance=10-15 -> orders only repost when optimal shifts >$0.10-0.15. Tests whether patient placement at 40-200 ticks can exploit mean reversion."
}
